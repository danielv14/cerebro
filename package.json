{
  "name": "cerebro",
  "version": "0.1.0",
  "description": "Permanent verbatim archive + search over all Claude Code sessions",
  "type": "module",
  "bin": {
    "cerebro": "src/cli.ts"
  },
  "scripts": {
    "cerebro": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build ./src/cli.ts --compile --outfile dist/cerebro"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/stopword": "^2.0.3",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "stopword": "^3.1.5"
  }
}
